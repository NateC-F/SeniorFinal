<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="460.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniorfinal.Controllers.CreateAccountController">
   <children>
      <VBox prefHeight="400.0" prefWidth="600.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Account Name" />
            <TextField fx:id="nameField" promptText="Enter Name..." />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Account Password" />
            <TextField fx:id="passField" promptText="Enter Account Password..." />
            <Button fx:id="createButton" mnemonicParsing="false" onAction="#createAccount" text="CreateAccount" />
            <Text fx:id="accountCreateFlag" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" visible="false" />
         </children>
      </VBox>
   </children>

</AnchorPane>
