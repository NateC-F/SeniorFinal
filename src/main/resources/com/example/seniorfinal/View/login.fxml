<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniorfinal.Controllers.LoginController">
   <children>
      <HBox prefHeight="400.0" prefWidth="600.0">
         <children>
            <VBox prefHeight="400.0" prefWidth="300.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Account Name">
                     <VBox.margin>
                        <Insets left="10.0" />
                     </VBox.margin></Text>
                  <TextField fx:id="nameField" promptText="Enter Name...">
                     <VBox.margin>
                        <Insets left="10.0" />
                     </VBox.margin></TextField>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Account Password">
                     <VBox.margin>
                        <Insets left="10.0" />
                     </VBox.margin></Text>
                  <TextField fx:id="passField" promptText="Enter Account Password...">
                     <VBox.margin>
                        <Insets left="10.0" />
                     </VBox.margin></TextField>
                  <HBox prefHeight="31.0" prefWidth="300.0" spacing="130.0">
                     <children>
                        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#login" prefHeight="25.0" prefWidth="57.0" text="Login">
                           <HBox.margin>
                              <Insets left="10.0" top="5.0" />
                           </HBox.margin>
                        </Button>
                        <Button fx:id="createAccountButton" mnemonicParsing="false" onAction="#openCreateAccountWindow" prefHeight="25.0" prefWidth="115.0" text="Create Account">
                           <HBox.margin>
                              <Insets top="5.0" />
                           </HBox.margin>
                        </Button>
                     </children>
                  </HBox>
                  <Text fx:id="errorFlag" fill="RED" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" visible="false">
                     <VBox.margin>
                        <Insets left="10.0" />
                     </VBox.margin>
                  </Text>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
