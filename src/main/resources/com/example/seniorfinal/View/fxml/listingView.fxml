<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniorfinal.Controllers.ListingViewController">
   <children>
      <ImageView fx:id="itemImage" fitHeight="300.0" fitWidth="300.0" layoutX="100.0" layoutY="150.0" preserveRatio="true" />
      <VBox layoutX="450.0" layoutY="150.0" spacing="15.0">
         <Label fx:id="itemName" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Item Name" />
         <Label fx:id="itemDescription" maxWidth="400.0" text="Item description goes here..." wrapText="true" />
         <Label fx:id="itemLocation" text="Location: " />
         <Label fx:id="itemPrice" text="Price: $" />
         <HBox spacing="10.0"><Label text="Quantity:" />
            <ComboBox fx:id="quantityBox" prefWidth="100.0" promptText="Select Quantity" />
         </HBox>
         <Button onAction="#addToCart" prefWidth="150.0" text="Add to Cart" />
      </VBox>
      <Button layoutX="1018.0" layoutY="66.0" mnemonicParsing="false" onAction="#goBack" text="Return" />
      <Text fx:id="errorText" fill="RED" layoutX="450.0" layoutY="374.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" visible="false" />
   </children>
</AnchorPane>
