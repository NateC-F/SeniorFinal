<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>


<AnchorPane prefHeight="460.0" prefWidth="640.0"  xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniorfinal.Controllers.ListingEditController">
   <children>
      <VBox prefHeight="258.0" prefWidth="640.0">
         <children>
            <HBox prefHeight="27.0" prefWidth="640.0">
               <children>
                  <Label text="Update Name" />
                  <TextField fx:id="nameBox" promptText="Enter New Name..." />
               </children>
            </HBox>
            <HBox prefHeight="28.0" prefWidth="640.0">
               <children>
                  <Label text="Update Description" />
                  <TextArea fx:id="descriptionBox" prefHeight="49.0" prefWidth="200.0" promptText="Enter New Description..." />
               </children>
            </HBox>
            <HBox prefHeight="40.0" prefWidth="640.0">
               <children>
                  <Label text="Update Price" />
                  <TextField fx:id="priceBox" promptText="Enter New Price..." />
               </children>
            </HBox>
            <HBox prefHeight="25.0" prefWidth="640.0">
               <children>
                  <Label text="Update Quantity" />
                  <TextField fx:id="quantityBox" promptText="Enter new Quantity..." />
               </children>
            </HBox>
         </children>
      </VBox>
      <Button layoutX="26.0" layoutY="366.0" mnemonicParsing="false" onAction="#makeChanges" text="Confirm Changes" />
      <Button layoutX="26.0" layoutY="405.0" mnemonicParsing="false" onAction="#goBack" text="Cancel Changes" />
      <Text fx:id="errorText" fill="RED" layoutX="365.0" layoutY="422.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" />
   </children>
</AnchorPane>
