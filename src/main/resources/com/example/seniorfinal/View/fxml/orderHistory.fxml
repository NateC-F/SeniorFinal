<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniorfinal.Controllers.OrderHistoryController">
   <children>
      <Button layoutX="1207.0" layoutY="14.0" mnemonicParsing="false" onAction="#goBack" text="go back" />
      <TableView fx:id="orderTable" layoutX="15.0" layoutY="86.0" prefHeight="632.0" prefWidth="1210.0">
        <columns>
          <TableColumn fx:id="name" prefWidth="75.0" text="Listing Name" />
          <TableColumn fx:id="date" prefWidth="75.0" text="Sale Date" />
            <TableColumn fx:id="seller" prefWidth="75.0" text="Seller Name" />
            <TableColumn fx:id="price" prefWidth="75.0" text="Sale Amount" />
            <TableColumn fx:id="amount" prefWidth="75.0" text="Sale Quantity" />
            <TableColumn fx:id="location" prefWidth="75.0" text="Location" />
        </columns>
      </TableView>
      <Label layoutX="66.0" layoutY="18.0" text="Order History" />
   </children>
</AnchorPane>
