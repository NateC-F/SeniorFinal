<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniorfinal.Controllers.AdminViewController">
   <children>
      <MenuButton layoutX="14.0" layoutY="42.0" mnemonicParsing="false" text="MenuButton">
        <items>
          <MenuItem fx:id="menuAccounts" mnemonicParsing="false" text="Show Accounts" />
          <MenuItem fx:id="menuListings" mnemonicParsing="false" text="Show Listings" />
        </items>
      </MenuButton>
      <ListView fx:id="listView" layoutX="-1.0" layoutY="110.0" prefHeight="610.0" prefWidth="1280.0" />
      <Button layoutX="1185.0" layoutY="39.0" mnemonicParsing="false" onAction="#close" text="Close App">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
