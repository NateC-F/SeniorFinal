<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="287.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniorfinal.Controllers.CreateAccountController">
   <children>
      <VBox prefHeight="126.0" prefWidth="500.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Account Name" />
            <TextField fx:id="nameField" promptText="Enter Name..." />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Account Password" />
            <TextField fx:id="passField" promptText="Enter Account Password..." />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Confirm Password" />
            <TextField fx:id="passField2" promptText="Confirm Account Password..." />
         </children>
      </VBox>
      <Button fx:id="createButton" layoutX="231.0" layoutY="133.0" mnemonicParsing="false" onAction="#createAccount" text="CreateAccount" />
      <Text fx:id="accountCreateFlag" fill="RED" layoutX="120.0" layoutY="55.0" strokeType="OUTSIDE" strokeWidth="0.0">
         <font>
            <Font size="14.0" />
         </font>
      </Text>
      <ProgressBar fx:id="passwordStrengthBar" layoutX="120.0" layoutY="81.0" prefHeight="19.0" prefWidth="200.0" progress="0.0" />
      <Text fx:id="strengthText" layoutX="325.0" layoutY="96.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Too Weak">
         <font>
            <Font size="14.0" />
         </font>
      </Text>
      <Label layoutX="15.0" layoutY="125.0" text="A Password Must Be:">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <Label layoutX="15.0" layoutY="145.0" text="8 Characters Long">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <Label layoutX="15.0" layoutY="165.0" text="Include 1 Number">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <Label layoutX="15.0" layoutY="185.0" text="Include '!@#$%^&amp;*()'">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <Text fx:id="succsessText" fill="LIME" layoutX="231.0" layoutY="170.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Account Successfully Made" visible="false" />
   </children>

</AnchorPane>
