<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniorfinal.Controllers.CheckoutController">
   <children>
      <Button layoutX="437.0" layoutY="204.0" onAction="#goBack" text="Cancel" />
      <Button layoutX="83.0" layoutY="204.0" onAction="#purchase" text="Buy" />
      <Text fx:id="totalPrice" layoutX="83.0" layoutY="291.0" text="Total: $" />
      <ListView fx:id="cartListView" layoutX="600.0" layoutY="100.0" prefHeight="400.0" prefWidth="500.0" />
      <Text fx:id="errorText" fill="RED" layoutX="83.0" layoutY="313.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" visible="false" />
   </children>
</AnchorPane>
