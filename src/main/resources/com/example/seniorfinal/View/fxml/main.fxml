<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniorfinal.Controllers.MainController">
   <children>
      <HBox prefHeight="16.0" prefWidth="1280.0">
         <children>
            <Button mnemonicParsing="false" onAction="#openSelfProfile" prefHeight="30.0" prefWidth="77.0" text="Profile">
               <font>
                  <Font size="14.0" />
               </font></Button>
            <Button mnemonicParsing="false" onAction="#newListing" prefHeight="30.0" prefWidth="126.0" text="Create Listing">
               <HBox.margin>
                  <Insets left="50.0" />
               </HBox.margin>
               <font>
                  <Font size="14.0" />
               </font>
            </Button>
            <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#logoutOnClick" prefHeight="30.0" prefWidth="73.0" text="Logout">
               <HBox.margin>
                  <Insets left="50.0" />
               </HBox.margin>
               <font>
                  <Font size="14.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#openCheckOut" text="Check Out">
               <HBox.margin>
                  <Insets left="50.0" />
               </HBox.margin>
               <font>
                  <Font size="14.0" />
               </font>
            </Button>
            <Text fx:id="cartText" fill="RED" strokeType="OUTSIDE" strokeWidth="0.0" text="Cannot Enter Check Out, Add Items To Cart" visible="false">
               <font>
                  <Font size="14.0" />
               </font>
               <HBox.margin>
                  <Insets left="5.0" top="5.0" />
               </HBox.margin>
            </Text>
         </children>
      </HBox>
      <ListView fx:id="listingHolder" layoutY="101.0" prefHeight="620.0" prefWidth="1280.0" />
      <MenuButton fx:id="filter" layoutX="8.0" layoutY="55.0" mnemonicParsing="false" text="Filter Listings By Category">
        <items>
          <MenuItem mnemonicParsing="false" text="Action 1" />
          <MenuItem mnemonicParsing="false" text="Action 2" />
        </items>
      </MenuButton>
   </children>
</AnchorPane>
