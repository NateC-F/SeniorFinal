SELECT l.listing_id, l.listing_name, l.listing_price, u.user_name, c.category_name, l.listing_start, l.listing_end
FROM listing l
JOIN user_profile u ON l.user_id = u.user_id
JOIN listing_category lc ON l.listing_id = lc.listing_id
JOIN item_category c ON lc.category_id = c.category_id;









