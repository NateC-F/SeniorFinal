-- ============================
--         TABLE EVENTS
-- ============================

-- DEACTIVATE EXPIRED LISTINGS
DELIMITER //
CREATE EVENT deactivate_expired_listings
ON SCHEDULE EVERY 1 DAY
STARTS CURRENT_TIMESTAMP
DO
BEGIN
    UPDATE listing
    SET listing_active = FALSE
    WHERE listing_active = TRUE
      AND listing_end < NOW();
END //
DELIMITER ;

-- DELETES AND ARCHIVES OLD LISTINGS
DELIMITER //
CREATE EVENT delete_old_listings
ON SCHEDULE EVERY 1 DAY
STARTS CURRENT_TIMESTAMP
DO
BEGIN
	INSERT INTO listing_archive
	SELECT * FROM listing
	WHERE listing_end < (NOW() - INTERVAL 1 MONTH);
	DELETE FROM listing
	WHERE listing_end < (NOW() - INTERVAL 1 MONTH);
END //
DELIMITER ;

