-- Create Listing
DELIMITER //
CREATE PROCEDURE create_listing(IN listing_input_name VARCHAR(50), IN listing_input_description VARCHAR(1000), IN listing_input_userID INT, IN listing_input_price INT, IN listing_input_endTime DATE,
								IN listing_input_state VARCHAR(3), IN listing_input_town VARCHAR(50), IN listing_input_longitude DECIMAL(9,6), IN listing_input_latitude DECIMAL(9,6), IN listing_input_quantity INT,
                                IN listing_input_categoryID INT, IN listing_input_image LONGBLOB)
BEGIN
	IF (listing_input_endTime IS NULL) THEN
        SET listing_input_endTime = ( (CURDATE()) + INTERVAL 3 DAY);
	END IF;

	INSERT INTO listing(listing_name, listing_description, user_id, listing_price, listing_end, listing_state, listing_town, listing_longitude, listing_latitude, listing_quantity, listing_picture)
    VALUES (listing_input_name, listing_input_description, listing_input_userID, listing_input_price, listing_input_endTime,
		   listing_input_state, listing_input_town, listing_input_longitude, listing_input_latitude, listing_input_quantity, listing_input_image);

	INSERT INTO listing_category(listing_id, category_id)
    VALUES (LAST_INSERT_ID(),listing_input_categoryID);

END //
DELIMITER ;

-- Buy Listing
DELIMITER //
CREATE PROCEDURE buy_listing(IN listing_input_id INT, IN listing_buyer_id INT, IN purchase_amount INT)
BEGIN
    DECLARE seller_variable_id INT;
    DECLARE selling_price INT;
    DECLARE is_active BOOLEAN;
    DECLARE current_quantity INT;
    DECLARE total_price INT;
    START TRANSACTION;

    SELECT user_id, listing_price, listing_active, listing_quantity
    INTO seller_variable_id, selling_price, is_active, current_quantity
    FROM listing
    WHERE listing_id = listing_input_id
    FOR UPDATE;


    IF seller_variable_id IS NULL THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Listing does not exist';
    END IF;

    IF is_active = FALSE THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Item cannot be purchased: listing is inactive';
    END IF;

	IF purchase_amount > current_quantity THEN
		SIGNAL SQLSTATE '45000'
		SET MESSAGE_TEXT = 'Not enough quantity, quantity updated ';
	END IF;

    SET total_price = selling_price * purchase_amount;

    INSERT INTO order_history(
        listing_id,
        buyer_id,
        seller_id,
        purchase_price,
        purchase_quantity
    )
    VALUES (
        listing_input_id,
        listing_buyer_id,
        seller_variable_id,
        total_price,
        purchase_amount
    );

    UPDATE listing
    SET
        listing_quantity = listing_quantity - purchase_amount,
        listing_active = CASE
            WHEN listing_quantity - purchase_amount <= 0 THEN FALSE
            ELSE listing_active
        END
    WHERE listing_id = listing_input_id;
    COMMIT;

END //
DELIMITER ;

-- Delete Listing
DELIMITER //
CREATE PROCEDURE delete_listing(IN p_listing_id INT)
BEGIN
    DELETE FROM listing
    WHERE listing_id = p_listing_id;
END //
DELIMITER ;

-- Gets Order History
DELIMITER //
CREATE PROCEDURE get_order_history(IN p_buyer_id INT)
BEGIN
    SELECT
        o.purchase_date,
        o.purchase_price,
        o.purchase_quantity,
        l.listing_name,
        l.listing_latitude,
        l.listing_longitude,
        seller.user_name AS seller_name,
        buyer.user_name AS buyer_name

    FROM order_history o
    JOIN listing l
        ON o.listing_id = l.listing_id

    JOIN user_profile seller
        ON o.seller_id = seller.user_id

    JOIN user_profile buyer
        ON o.buyer_id = buyer.user_id

    WHERE o.buyer_id = p_buyer_id
    ORDER BY o.purchase_date DESC;
END //
DELIMITER ;

-- Gets Sale History
DELIMITER //
CREATE PROCEDURE get_sale_history(IN p_seller_id INT)
BEGIN
    SELECT
        o.purchase_date,
        o.purchase_price,
        o.purchase_quantity,
        l.listing_name,
        l.listing_latitude,
        l.listing_longitude,
        buyer.user_name AS buyer_name,
        seller.user_name AS seller_name

    FROM order_history o
    JOIN listing l
        ON o.listing_id = l.listing_id

    JOIN user_profile seller
        ON o.seller_id = seller.user_id

    JOIN user_profile buyer
        ON o.buyer_id = buyer.user_id

    WHERE o.seller_id = p_seller_id
    ORDER BY o.purchase_date DESC;
END //
DELIMITER ;

