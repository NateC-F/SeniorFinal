-- PREVENT NEGATIVE PRICES
DELIMITER //
CREATE TRIGGER prevent_negative_price
BEFORE INSERT ON listing
FOR EACH ROW
BEGIN
    IF NEW.listing_price < 0 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Price Cannot Be Negative';
    END IF;
END //
DELIMITER ;

-- UPON ZERO QUANTITY MAKE INACTIVE
DELIMITER //
CREATE TRIGGER listing_quantity_zero
BEFORE UPDATE ON listing
FOR EACH ROW
BEGIN
    IF NEW.listing_quantity = 0 THEN
        SET NEW.listing_active = FALSE;
    END IF;
END//
DELIMITER ;

