-- =================================================================================
CREATE TABLE listing_category
(
    listing_id         INT,
    category_id        INT,

    CONSTRAINT listing_category_primarykey
        PRIMARY KEY (listing_id, category_id),

    CONSTRAINT listing_category_listingid_foreignkey
        FOREIGN KEY (listing_id)
        REFERENCES listing (listing_id)
        ON DELETE CASCADE ON UPDATE CASCADE,

    CONSTRAINT listing_category_categoryid_foreignkey
        FOREIGN KEY (category_id)
        REFERENCES item_category (category_id)
        ON DELETE CASCADE ON UPDATE CASCADE
);

-- ============================
--       ORDER HISTORY
-- ============================

CREATE TABLE order_history
(
    order_id        INT    PRIMARY KEY 		AUTO_INCREMENT,
    listing_id      INT        	 			NOT NULL,
    buyer_id  		INT         			NOT NULL,
    seller_id 		INT         			NOT NULL,
    purchase_price  INT   					NOT NULL,
    purchase_quantity INT       			DEFAULT 1,
    purchase_date   DATE   					DEFAULT (CURDATE()),
    order_status    VARCHAR(20)	 			DEFAULT 'Completed',

    CONSTRAINT order_listing_fk
        FOREIGN KEY (listing_id)
        REFERENCES listing(listing_id)
        ON DELETE CASCADE ON UPDATE CASCADE,

    CONSTRAINT order_buyer_fk
        FOREIGN KEY (buyer_id)
        REFERENCES user_profile(user_id)
        ON DELETE CASCADE ON UPDATE CASCADE,

    CONSTRAINT order_seller_fk
        FOREIGN KEY (seller_id)
        REFERENCES user_profile(user_id)
        ON DELETE CASCADE ON UPDATE CASCADE
);

-- =================================================================================
CREATE TABLE listing_archive LIKE listing;  -- Does as name suggests, it will archive old listings
